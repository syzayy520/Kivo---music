{
  "version": 5,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "p0b-configure-smoke",
      "displayName": "P0-B Configure Smoke",
      "description": "Configure-only smoke for P0-B skeleton. No build or test presets. Validates CMake 3.24+ can parse project structure.",
      "binaryDir": "${sourceDir}/.build/p0b-configure-smoke",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF"
      }
    },
    {
      "name": "p0c-contract-debug",
      "displayName": "P0-C Contract Debug",
      "description": "Configure and build contract tests in Debug mode.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/.build/p0c-contract-debug",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "p0c-contract-build",
      "displayName": "P0-C Contract Build",
      "description": "Build contract tests.",
      "configurePreset": "p0c-contract-debug",
      "targets": ["kivo_contract_tests"]
    },
    {
      "name": "p0c-capability-build",
      "displayName": "P0-012 Capability Build",
      "description": "Build capability tests.",
      "configurePreset": "p0c-contract-debug",
      "targets": ["kivo_capability_tests"]
    }
  ],
  "testPresets": [
    {
      "name": "p0c-contract-test",
      "displayName": "P0-C Contract Test",
      "description": "Run contract tests.",
      "configurePreset": "p0c-contract-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "p0c-capability-test",
      "displayName": "P0-012 Capability Test",
      "description": "Run capability tests.",
      "configurePreset": "p0c-contract-debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
